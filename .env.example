# Copy this file to .env and fill in your keys. NEVER commit .env.

# Groq (primary LLM provider, OpenAI-compatible API)
GROQ_API_KEY=

# NVIDIA NIM (fallback LLM provider, OpenAI-compatible API)
NVIDIA_NIM_API_KEY=

# --- Per-agent model overrides (optional) ---
# Leave blank to use GROQ_MODEL for that agent. Set to any Groq model id to
# override just that agent. Useful Groq chat models (as of 2026-06):
#   llama-3.3-70b-versatile   (default; strong all-rounder)
#   llama-3.1-8b-instant      (fast/cheap; good for the parallel workers)
#   openai/gpt-oss-120b       (large; strong reasoning — good for the Judge)
#   openai/gpt-oss-20b        (mid-size reasoning)
#   qwen/qwen3-32b            (reasoning)
#   meta-llama/llama-4-scout-17b-16e-instruct
# List your account's models: GET https://api.groq.com/openai/v1/models
MODEL_TECHNICALS=
MODEL_FUNDAMENTALS=
MODEL_NEWS=
MODEL_BULL=
MODEL_BEAR=
MODEL_JUDGE=

# Telegram bot (verdict delivery)
TELEGRAM_BOT_TOKEN=
# Where to deliver verdicts. Message your bot once, then read the chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# Discord bot (inbound: chat a stock name, get a verdict). Create an app +
# bot at https://discord.com/developers/applications and paste the bot token.
DISCORD_BOT_TOKEN=
# Optional: your server id -> slash commands appear instantly (global sync is slow).
DISCORD_GUILD_ID=
# Set true ONLY after enabling "Message Content Intent" in the Developer Portal,
# to also accept plain-text messages (not just the /stock command).
DISCORD_MESSAGE_CONTENT=

# Email fallback (used if Telegram delivery fails or is unconfigured).
# For Gmail: create an App Password (Google Account -> Security -> App passwords)
# and use it below. Leave blank to disable the email channel.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
EMAIL_TO=
